{
  "expo": {
    "name": "LiteraKids",
    "slug": "literakids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.literakids.app",
      "icon": "./src/assets/images/logo.png"
    },
    "android": {
      "package": "com.hauzanedu.literakids",
      "versionCode": 1,
      "icon": "./src/assets/images/logo.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "ac3c7688-f573-49ef-9540-a125fa5d1f3c"
      }
    }
  }
}
